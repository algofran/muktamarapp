```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js.map
*.ts.map

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temp files
*.tmp

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.Pytest_cache/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Compiled CSS/JS
*.min.js
*.min.css
```